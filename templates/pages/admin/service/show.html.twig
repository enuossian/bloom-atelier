{% extends 'themes/base_visitor.html.twig' %}

{% block title %}Détail du service – {{ service.name }}{% endblock %}

{% block description %}
Consultez les informations détaillées du service "{{ service.name }}".
{% endblock %}

{% block keywords %}
service, détail, {{ service.name }}
{% endblock %}

{% block main %}
<section class="py-5">
    <div class="container">

        <div class="row g-5 align-items-center">

            <!-- Image -->
            <div class="col-lg-6">
                {% if service.image %}
                    <img src="{{ asset('uploads/services/' ~ service.image) }}" 
                         class="img-fluid rounded-4 shadow" 
                         alt="{{ service.name }}">
                {% else %}
                    <div class="bg-light rounded-4 d-flex align-items-center justify-content-center shadow"
                         style="height: 400px;">
                        <i class="bi bi-bag-heart fs-1 text-muted"></i>
                    </div>
                {% endif %}
            </div>

            <!-- Infos principales -->
            <div class="col-lg-6">

                <h1 class="fw-bold mb-3">
                    {{ service.name }}
                </h1>

                <div class="d-flex align-items-center gap-4 mb-4">
                    <h2 class="fw-bold text-primary mb-0">
                        {{ service.price }} €
                    </h2>

                    <div class="border-start ps-4">
                        <i class="bi bi-clock"></i>
                        {{ service.displayDuration }}
                    </div>
                </div>

                <p class="lead text-muted mb-4">
                    {{ service.description }}
                </p>

                <a href="#reservation" class="btn btn-lg btn-dark px-4">
                    Réserver une session
                </a>
            </div>
        </div>
    </div>
</section>
{% endblock %}