{% extends 'themes/base_admin.html.twig' %}

{% block title %}Ajout d'un service{% endblock %}

{% block description %}Ajouter un nouveau service{% endblock %}

{% block keywords %}Ajouter, nouveau, services{% endblock %}

{# Tiny_mce #}
{% block tiny_mce %}
    <script src="https://cdn.tiny.cloud/1/69xzl36nni7vxdxavmfn6y5p650szgrx9xbla8n8lkds7qoa/tinymce/8/tinymce.min.js" referrerpolicy="origin" crossorigin="anonymous"></script>

<script>
    tinymce.init({
        selector: 'textarea'
    });
</script>
{% endblock %}

{% block main %}
    <h1 class="text-center my-4 display-5">Nouveau service</h1>
    <div class="container">

        <div class="row">
            <div class="col-md-10 mx-auto bg-light shadow p-4">
                {{ form_start(serviceForm) }}
                <div class="mb-3">
                    <label for="service_form_name">Nom du service<span class="text-danger">*</span>
                    </label>
                    {{ form_widget(serviceForm.name) }}
                    <div class="text-danger">{{ form_errors(serviceForm.name) }}</div>
                </div>

                <div class="mb-3">
                    <label for="service_form_description">Description<span class="text-danger">*</span>
                    </label>
                    {{ form_widget(serviceForm.description) }}
                    <div class="text-danger">{{ form_errors(serviceForm.description) }}</div>

                </div>
                <div class="mb-3">
                    <label for="service_form_imageFile_file">Image
                    </label>
                    {{ form_widget(serviceForm.imageFile) }}
                    <div class="text-danger">{{ form_errors(serviceForm.imageFile) }}</div>

                </div>
                <div class="row">
                    <div class="col-lg-6 mb-3">
                        <label for="service_form_price">Prix
                            <span class="text-danger">*</span>
                        </label>
						<div class="input-group">
                        	{{ form_widget(serviceForm.price) }}
							<span class="input-group-text">€</span>
						</div>
                        <div class="text-danger">{{ form_errors(serviceForm.price) }}</div>

                    </div>
                    <div class="col-lg-6 mb-3">
                        <label for="service_form_duration">Durée
                            <span class="text-danger">*</span>
                        </label>
                        {{ form_widget(serviceForm.duration) }}
                        <div class="text-danger">{{ form_errors(serviceForm.duration) }}</div>

                    </div>
                    <div class="text-center">
                        <input formnovalidate type="submit" value="Ajouter" class="btn btn-form text-white w-25">
                    </div>
                </div>
                {{ form_end(serviceForm) }}
            </div>
        </div>
    </div>
{% endblock %}