{% extends 'themes/base_admin.html.twig' %}

{% block title %}Ajout d'un service
{% endblock %}

{% block description %}Ajouter un nouveau service
{% endblock %}

{% block keywords %}Ajouter, nouveau, services
{% endblock %}

{# Tiny_mce #}
{% block tiny_mce %}
	<script src="https://cdn.tiny.cloud/1/69xzl36nni7vxdxavmfn6y5p650szgrx9xbla8n8lkds7qoa/tinymce/8/tinymce.min.js" referrerpolicy="origin" crossorigin="anonymous"></script>
	<script>
		tinymce.init({selector: 'textarea#service_form_description'});
	</script>
{% endblock %}

{% block main %}
	<h1 class="display-6 text-center mb-5 cormorant-garamond">Nouveau service</h1>
	<div class="d-flex justify-content-end align-items-center my-5">
		<a href="{{ path('app_admin_service_index') }}" class="btn btn-brown px-4 py-2">← Retour</a>
	</div>
	<div class="container mb-5">
		<div class="row">
			<div class="col-md-10 mx-auto container-bg shadow p-4">
				{{ form_start(serviceForm) }}
				<div class="mb-3">
					<label for="service_form_name" class="form-label">Nom du service<span class="text-danger">*</span>
					</label>
					{{ form_widget(serviceForm.name) }}
					<div class="text-danger">{{ form_errors(serviceForm.name) }}</div>
				</div>
				<div class="mb-3">
					<label for="service_form_shortDescription" class="form-label">Courte description<span class="text-danger">*</span>
					</label>
					{{ form_widget(serviceForm.shortDescription) }}
					<div class="text-danger">{{ form_errors(serviceForm.shortDescription) }}</div>
				</div>
				<div class="mb-3">
					<label for="service_form_description" class="form-label">Description complète<span class="text-danger">*</span>
					</label>
					{{ form_widget(serviceForm.description) }}
					<div class="text-danger">{{ form_errors(serviceForm.description) }}</div>
				</div>
				<div class="mb-3">
					<label for="service_form_imageFile_file" class="form-label">Image
					</label>
					{{ form_widget(serviceForm.imageFile) }}
					<div class="text-danger">{{ form_errors(serviceForm.imageFile) }}</div>

				</div>
				<div class="row">
					<div class="col-lg-6 mb-3">
						<label for="service_form_price" class="form-label">Prix
							<span class="text-danger">
								*</span>
						</label>
						<div class="input-group">
							{{ form_widget(serviceForm.price) }}
							<span class="input-group-text">€</span>
						</div>
						<div class="text-danger">{{ form_errors(serviceForm.price) }}</div>

					</div>
					<div class="col-lg-6 mb-3">
						<label for="service_form_duration" class="form-label">Durée en minutes
							<span class="text-danger">
								*</span>
						</label>
						{{ form_widget(serviceForm.duration) }}
						<div class="text-danger">{{ form_errors(serviceForm.duration) }}</div>

					</div>
					<div class="text-center my-4">
						<input formnovalidate type="submit" value="Ajouter" class="btn btn-brown px-4 py-2 w-25">
					</div>
				</div>
				{{ form_end(serviceForm) }}
			</div>
		</div>
	</div>
{% endblock %}
