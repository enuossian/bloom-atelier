
{% extends 'themes/base_admin.html.twig' %}

{% block title %}Modifier les paramètres du site {% endblock %}

{% block description %}Modification des paramètres du site{% endblock %}

{% block main %}
    <h1 class="text-center my-3 display-5">Modification des paramètres du site</h1>

	{% include 'components/_alert.html.twig' %}

    <div class="container mt-5">
        <div class="row">
            <div class="col-md-10 col-lg-5 mx-auto p-4 shadow bg-light">
                {{ form_start(settingForm) }}
                    <div class="mb-3">
                        <label for="setting_form_email">Email</label>
                        {{ form_widget(settingForm.email) }}
                        <div class="text-danger">{{ form_errors(settingForm.email) }}</div>
                    </div>
                    <div class="mb-3">
                        <label for="setting_form_phone">Téléphone</label>
                        {{ form_widget(settingForm.phone) }}
                        <div class="text-danger">{{ form_errors(settingForm.phone) }}</div>
                    </div>
                    <div class="d-flex justify-content-center align-items-center">
                        <input formnovalidate type="submit" value="Modifier" class="btn btn-dark shadow">
                    </div>
                {{ form_end(settingForm) }}
            </div>
        </div>
    </div>
        
{% endblock %}
