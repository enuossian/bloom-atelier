
{% extends 'themes/base_admin.html.twig' %}

{% block title %}Les paramètres du site {% endblock %}

{% block description %}Consulter les paramètres du site{% endblock %}

{% block main %}
    <h1 class="display-6 text-center mb-3 cormorant-garamond">Paramètres du site</h1>

	{% include 'components/_alert.html.twig' %}

    <div class="container mt-5">
        <div class="row">
            <div class="col-md-10 col-lg-5 mx-auto p-4 shadow container-bg">
                <div>
                    <p><strong>Email </strong>: {{setting.email}}</p>
                    <p><strong>Téléphone </strong>: {{setting.phone}}</p>
                    <div class="d-flex justify-content-center align-items-center mt-4">
                        <a href="{{path('app_admin_setting_edit', {'id':setting.id})}}" class="btn btn-brown px-4 py-2">Modifier les paramètres</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
        
{% endblock %}
