{% extends 'themes/base_admin.html.twig' %}

{% block title %}Liste des utilisateurs{% endblock %}

{% block description %}Liste de tous les utilisateurs{% endblock %}

{% block j_query %}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
{% endblock %}

{% block data_tables %}
    <link href="https://cdn.datatables.net/v/bs5/dt-2.3.7/datatables.min.css" rel="stylesheet" integrity="sha384-MnxpJFHU9dTMYXshJqBDA0d93sG4KKAFEEzynAaDqcPP7BYh11O5HxbJ6iLDWOXS" crossorigin="anonymous">
 
    <script src="https://cdn.datatables.net/v/bs5/dt-2.3.7/datatables.min.js" integrity="sha384-7rAjATpiK3MtvKnoDf5WQz4O8W+3kpl4Jm82apgJgNkeUmZ59yjJT6LqlJpYqhVK" crossorigin="anonymous"></script>

    <script>
        $(document).ready( function () {
            $('#myTable').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/2.3.7/i18n/fr-FR.json',
                }
            });
        } );
    </script>
{% endblock %}

{% block main %}
    <h1 class="display-6 text-center mb-3 cormorant-garamond">Liste des utilisateurs</h1>

	{% include 'components/_alert.html.twig' %}

    <div class="table-responsive">
        <table id="myTable" class="table table-striped table-hover table-bordered">
            <thead class="table-danger">
                <tr>
                    <th class="fw-bold">Id</th>
                    <th class="fw-bold">Prénom</th>
                    <th class="fw-bold">Nom</th>
                    <th class="fw-bold">Email</th>
                    <th class="fw-bold">Statut</th>
                    <th class="fw-bold">Rôles</th>
                    <th class="fw-bold">Créé le</th>
                    <th class="fw-bold">Modifié le</th>
                    <th class="fw-bold">Options</th>
                </tr>
            </thead>
            <tbody> 
                {% for user in users %}
                    <tr>
                        <td>{{ user.id }}</td>
                        <td>{{ user.firstName }}</td>
                        <td>{{ user.lastName }}</td>
                        <td>{{ user.email }}</td>                       
                        <td> 
                            {% if user.verifiedAt %}
                                Compte vérifié le {{ user.verifiedAt|format_date() }}
                            {% else %}
                                Compte non vérifié
                            {% endif %}
                        </td>
                        <td>
                            {% for role in user.roles %}
                                <span class="badge text-bg-secondary">{{ role }}</span>
                            {% endfor %}
                        </td>                       
                        <td>{{ user.createdAt|format_date() }}</td>
                        <td>{{ user.updatedAt|format_date() }}</td>
                        <td class="align-middle">
                             <div class="d-flex justify-content-center align-items-center gap-1">
                                {% if 'ROLE_SUPER_ADMIN' not in user.roles %}
                                    <a href="{{path('app_admin_user_edit_roles', {'id':user.id})}}" class="btn btn-sm btn-secondary">Modifier</a>                                   
                                    <form action="{{path('app_admin_user_delete', {'id':user.id})}}" method="post">
                                        <input type="hidden" name="csrf_token" value="{{csrf_token('delete-user-'~user.id)}}">
                                        <input type="submit" value="Supprimer" class="btn btn-sm btn-danger" onclick="return confirm('Confirmez-vous la suppression de ce compte ?')">
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    
    
    
{% endblock %}
