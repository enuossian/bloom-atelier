{% extends 'themes/base_admin.html.twig' %}

{% block title %}Modification des rôles de cet utilisateur
	{{ user.id }}
	:
	{{ user.firstName }}{{ user.lastName }}
{% endblock %}

{% block description %}Modifier les roles de cet utilisateur
	{{ user.id }}
	:
	{{ user.firstName }}{{ user.lastName }}
{% endblock %}

{% block j_query %}
	<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
{% endblock %}

{% block select2 %}
	<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet"/>
	<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
	<script>
		$(document).ready(function () {
$('#edit_user_roles_form_roles').select2();
});
	</script>
{% endblock %}

{% block main %}
	<h1 class="display-6 text-center mb-3 cormorant-garamond">Modifier les rôles de l'utilisateur
		{{ user.id }}
		:
		{{ user.firstName }}
		{{ user.lastName }}</h1>

	<div class="container mt-5">
		<div class="d-flex justify-content-end align-items-center my-5">
			<a href="{{ path('app_admin_user_index') }}" class="btn btn-brown rounded-0 px-4 py-2">← Retour</a>
		</div>
		<div class="row">
			<div class="col-md-10 col-lg-6 mx-auto p-4 container-bg shadow">
				{{ form_start(userRolesForm) }}
				<div class="mb-3">
					<label for="edit_user_roles_form_roles">Choisissez les rôles</label>
					{{ form_widget(userRolesForm.roles) }}
					<div class="text-danger">{{ form_errors(userRolesForm.roles) }}</div>
				</div>
				<div>
					<input formnovalidate type="submit" value="Modifier" class="btn btn-dark w-100">
				</div>
				{{ form_end(userRolesForm) }}
			</div>
		</div>
	</div>
{% endblock %}
