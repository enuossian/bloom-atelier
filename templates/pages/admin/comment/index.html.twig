{% extends 'themes/base_admin.html.twig' %}

{% block title %}Liste des avis{% endblock %}

{% block description %}Liste de toutes les avis{% endblock %}

{% block keywords %} Liste, consulter, avis{% endblock %}

{% block j_query %}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
{% endblock %}

{% block data_tables %}
    <link href="https://cdn.datatables.net/v/bs5/dt-2.3.7/datatables.min.css" rel="stylesheet" integrity="sha384-MnxpJFHU9dTMYXshJqBDA0d93sG4KKAFEEzynAaDqcPP7BYh11O5HxbJ6iLDWOXS" crossorigin="anonymous">
 
    <script src="https://cdn.datatables.net/v/bs5/dt-2.3.7/datatables.min.js" integrity="sha384-7rAjATpiK3MtvKnoDf5WQz4O8W+3kpl4Jm82apgJgNkeUmZ59yjJT6LqlJpYqhVK" crossorigin="anonymous"></script>

    <script>
        $(document).ready( function () {
            $('#myTable').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/2.3.7/i18n/fr-FR.json',
                }
            });
        } );
    </script>
{% endblock %}

{% block main %}
	<h1 class="display-6 text-center mb-3 cormorant-garamond">Liste des avis</h1>

	{% include 'components/_alert.html.twig' %}

	<div class="table-responsive">
		<table id="myTable" class="table table-hover table-bordered">
			<thead class="table-danger">
				<tr>
					<th class="text-center">Utilisateur</th>
					<th class="text-center">Service</th>
					<th class="text-center">Note</th>
					<th class="text-center">Contenu</th>
					<th class="text-center">Statut</th>
					<th class="text-center">Créé le</th>
					<th class="text-center">Options</th>
				</tr>
			</thead>
			<tbody>
				{% for comment in comments %}
					<tr>
						<td class="text-center">{{ comment.user.firstName }} {{ comment.user.lastName }}</td>
						<td class="text-center">{{ comment.service.name }}</td>
						<td class="text-center">{{ comment.rating }}</td>
                        <td class="text-center">
							<a href="#" class="btn btn-sm btn-secondary" data-bs-toggle="modal" data-bs-target="#modal-{{comment.id}}">Lire</a>

							<!-- Modal -->
							<div class="modal fade" id="modal-{{comment.id}}" tabindex="-1" aria-labelledby="modal-{{comment.id}}-title" aria-hidden="true" role="dialog">
								<div class="modal-dialog">
									<div class="modal-content">
										<div class="modal-header">
											<h1 class="modal-title fs-5" id="modal-{{comment.id}}-title">Avis de {{ comment.user.firstName }} {{ comment.user.lastName }}</h1>
											<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
										</div>
										<div class="modal-body">
                                            {{ comment.content|nl2br }}
										</div>
										<div class="modal-footer">
											<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
										</div>
									</div>
								</div>
							</div>
						</td>
						<td class="align-middle">
                            <div class="d-flex flex-column justify-content-center align-items-center gap-1">
                                {% if comment.isVisible %}
                                    <p>Visible</p>
                                {% else %}
                                    <p>Masqué</p>
                                {% endif %}
                                <form action="{{ path('app_admin_comment_visible', {'id': comment.id})}}" method="post">
                                    <div class="form-check form-switch">
                                        <input type="hidden" name="csrf_token" value="{{ csrf_token('visible-comment-'~comment.id) }}">
                                        <input 
                                            class="form-check-input" 
                                            type="checkbox" 
                                            role="switch"
                                            onclick="return confirm('Confirmez-vous cette action ?')"
                                            onchange="this.form.submit()"
                                            {{ comment.isVisible ? 'checked' : ''}}
                                            >
                                    </div>
                                </form>
                            </div>
                        </td>
						<td class="text-center">{{ comment.createdAt|format_date() }}</td>
						<td class="align-middle">
							<div class="d-flex justify-content-center align-items-center">
								<form action="{{path('app_admin_comment_delete', {'id': comment.id})}}" method="POST">
									<input type="hidden" name="csrf_token" value="{{csrf_token('comment-delete-'~comment.id)}}">
									<input type="submit" value="Supprimer" onclick="return confirm('Confirmez-vous la suppression de cet avis ?')" class="btn btn-sm btn-danger">
								</form>
							</div>
						</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
	</div>
{% endblock %}