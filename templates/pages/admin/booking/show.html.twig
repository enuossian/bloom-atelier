{% extends 'themes/base_admin.html.twig' %}

{% block title %}
	Détails de la réservation
	{{ booking.reference }}
{% endblock %}

{% block description %}
	Consultez les informations détaillées de la réservation
	{{ booking.reference }}
{% endblock %}

{% block keywords %}
	Réservation, Détail, Admin
{% endblock %}

{% block main %}

	<h1 class="display-6 text-center cormorant-garamond">Réservation
		{{ booking.reference }}</h1>
	<div class="container">
		<div class="d-flex justify-content-end align-items-center my-5">
			<a href="{{ path('app_admin_booking_index') }}" class="btn btn-brown rounded-0 px-4 py-2">← Retour</a>
		</div>
	</div>
	<div class="row g-3 mb-5">
		<div class="col-4">
			<div class="card border rounded-0 p-4 container-bg text-center">
				<p class="pink small text-uppercase fw-light mb-1">Statut</p>
				<span class="cormorant-garamond fs-4">{{ booking.status.label() }}
				</span>
			</div>
		</div>
		<div class="col-4">
			<div class="card border rounded-0 p-4 container-bg text-center">
				<p class="pink small text-uppercase fw-light mb-1">Total</p>
				<span class="cormorant-garamond fs-4">{{ booking.totalAmount }}
					€</span>
			</div>
		</div>
		<div class="col-4">
			<div class="card border rounded-0 p-4 container-bg text-center">
				<p class="pink small text-uppercase fw-light mb-1">Sessions</p>
				<span class="cormorant-garamond fs-4">{{ booking.bookItems|length }}</span>
			</div>
		</div>
	</div>

	<div
		class="row g-4">

		{# Détails de la session #}
		{% if booking.bookItems|length > 0 %}

			<div class="col-12">
				<div class="card border rounded-0 p-4 container-bg h-100">
					<h2 class="cormorant-garamond pink fs-4 fw-light mb-4">Sessions réservées</h2>
					<table class="table table-hover mb-0 align-middle">
						<thead class="table-danger">
							<tr>
								<th>Service</th>
								<th>Date</th>
								<th>Prix</th>
							</tr>
						</thead>
						<tbody>
							{% for item in booking.bookItems %}
								<tr>
									<td>{{ item.session.service.name }}</td>
									<td>{{ item.session.startTime|format_datetime(pattern: "dd/MM/yyyy 'de' HH'h'mm 'à'") }}
										{{ item.session.endTime|format_datetime(pattern: "HH'h'mm") }}</td>
									<td>{{ item.price }}
										€</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			</div>
		{% endif %}

		<div class="col-12">
			<div class="card border rounded-0 p-4 container-bg">
				<h2 class="cormorant-garamond pink fs-4 fw-light mb-4">Client</h2>

				{% if booking.user %}
					<div class="row g-3">
						<div class="col-12 col-md-3">
							<p class="small text-uppercase pink fw-light mb-1">Nom</p>
							<span>{{ booking.user.lastName }}</span>
						</div>
						<div class="col-12 col-md-3">
							<p class="small text-uppercase pink fw-light mb-1">Prénom</p>
							<span>{{ booking.user.firstName }}</span>
						</div>
						<div class="col-12 col-md-3">
							<p class="small text-uppercase pink fw-light mb-1">Email</p>
							<span>{{ booking.user.email }}</span>
						</div>
						<div class="col-12 col-md-3">
							<p class="small text-uppercase pink fw-light mb-1">Inscrit le</p>
							<span>{{ booking.user.createdAt|format_datetime(pattern: "dd/MM/yyyy") }}</span>
						</div>
					</div>
				{% else %}
					<p class="text-muted fw-light">Utilisateur supprimé.</p>
				{% endif %}
			</div>
		</div>

	</div>
{% endblock %}
