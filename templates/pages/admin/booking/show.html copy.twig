{% extends 'themes/base_admin.html.twig' %}

{% block title %}Détails de la réservation {{ booking.reference }}{% endblock %}
{% block description %}Consultez les informations détaillées de la réservation {{ booking.reference }}{% endblock %}
{% block keywords %}Réservation, Détail, Admin{% endblock %}

{% block main %}
<div class="container py-5">

    <!-- Titre et bouton retour -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-5">
        <h1 class="display-6 text-center text-md-start cormorant-garamond mb-3 mb-md-0">
            Réservation {{ booking.reference }}
        </h1>
        <a href="{{ path('app_admin_booking_index') }}" class="btn btn-brown rounded-0 px-4 py-2">← Retour</a>
    </div>

    <!-- Résumé réservation -->
    <div class="row g-3 mb-5">
        <div class="col-12 col-md-4">
            <div class="card border rounded-0 p-4 container-bg text-center">
                <p class="pink small text-uppercase fw-light mb-1">Statut</p>
                <span class="cormorant-garamond fs-4">{{ booking.status.label() }}</span>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border rounded-0 p-4 container-bg text-center">
                <p class="pink small text-uppercase fw-light mb-1">Montant total</p>
                <span class="cormorant-garamond fs-4">
                    {{ booking.totalAmount|number_format(2, ',', ' ') }} €
                </span>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border rounded-0 p-4 container-bg text-center">
                <p class="pink small text-uppercase fw-light mb-1">Sessions</p>
                <span class="cormorant-garamond fs-4">{{ booking.bookItems|length }}</span>
            </div>
        </div>
    </div>

    <!-- Détails des sessions -->
    {% if booking.bookItems|length > 0 %}
        <div class="card border rounded-0 p-4 container-bg mb-5">
            <h2 class="cormorant-garamond pink fs-4 fw-light mb-4 text-center text-md-start">Sessions réservées</h2>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-danger">
                        <tr>
                            <th scope="col">Service</th>
                            <th scope="col">Date</th>
                            <th scope="col">Prix</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in booking.bookItems %}
                            <tr>
                                <td>{{ item.session.service.name }}</td>
                                <td>
                                    {{ item.session.startTime|format_datetime(pattern: "dd/MM/yyyy 'de' HH'h'mm 'à'") }}
                                    {{ item.session.endTime|format_datetime(pattern: "HH'h'mm") }}
                                </td>
                                <td>{{ item.session.service.price|number_format(2, ',', ' ') }} €</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% endif %}

    <!-- Détails du client -->
    <div class="card border rounded-0 p-4 container-bg">
        <h2 class="cormorant-garamond pink fs-4 fw-light mb-4 text-center text-md-start">Client</h2>
        <div class="row g-3 text-center text-md-start">
            <div class="col-12 col-md-4">
                <p class="small text-uppercase pink fw-light mb-1">Utilisateur</p>
                <span>{{ booking.user.firstName }} {{ booking.user.lastName }}</span>
            </div>
            <div class="col-12 col-md-4">
                <p class="small text-uppercase pink fw-light mb-1">Email</p>
                <span>{{ booking.user.email }}</span>
            </div>
            <div class="col-12 col-md-4">
                <p class="small text-uppercase pink fw-light mb-1">Inscrit le</p>
                <span>{{ booking.user.createdAt|format_datetime(pattern: "dd/MM/yyyy") }}</span>
            </div>
        </div>
    </div>
    <div class="col-12 mb-5">
			<div class="card border rounded-0 p-4 container-bg h-100">
				<h2 class="cormorant-garamond pink fs-4 fw-light mb-4">Notes internes</h2>
                {% if session.notes %}
                    <p>{{ session.notes }}</p>
                {% else %}
                    <p class="text-secondary">Aucune note pour le moment.</p>
                {% endif %}
			</div>
		</div>

</div>
{% endblock %}