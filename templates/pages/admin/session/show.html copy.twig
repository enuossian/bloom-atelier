{% extends 'themes/base_admin.html.twig' %}

{% block title %}Détails de la session {{ session.service.name}} du {{ session.startTime|format_datetime(pattern: "dd/MM/yyyy 'à' HH'h'mm") }}{% endblock %} 

{% block description %}Consultez les informations détaillées de la session {{ session.service.name}} du {{ session.startTime|format_datetime(pattern: "dd/MM/yyyy 'à' HH'h'mm") }}{% endblock %} 

{% block keywords %}Session, Détail, {{ session.service.name}}{% endblock %}

{% block main %}

<div class="container my-4">

    {# Header avec actions #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6 mb-1">{{ session.service.name }}</h1>
            <small class="text-muted">Réf. {{ session.reference }} · ID #{{ session.id }}</small>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_admin_session_index') }}" class="btn btn-outline-secondary btn-sm">← Retour</a>
            <a href="{{path('app_admin_session_edit', {'id': session.id})}}" class="btn btn-secondary btn-sm">Modifier</a>
        </div>
    </div>

    <div class="row g-4 align-items-stretch">

        {# Colonne gauche #}
        <div class="col-lg-8">

            {# Carte dates + statut #}
            <div class="card shadow-sm mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Informations de la session</h6>
                    <span class="badge fs-6 bg-{{ session.status.value == 'available' ? 'success' : (session.status.value == 'full' ? 'danger' : 'secondary') }}">
                        {{ session.status.label() }}
                    </span>
                </div>
                <div class="card-body">
                    <div class="row text-center mb-4">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <div class="p-3 bg-light rounded border">
                                <small class="text-muted d-block mb-1">Début</small>
                                <strong class="fs-5">{{ session.startTime|format_datetime(pattern: "dd/MM/yyyy 'à' HH'h'mm") }}</strong>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded border">
                                <small class="text-muted d-block mb-1">Fin</small>
                                <strong class="fs-5">{{ session.endTime|format_datetime(pattern: "dd/MM/yyyy 'à' HH'h'mm") }}</strong>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <h6 class="text-muted">Lieu</h6>
                            <p class="mb-0">{{ session.location ?: 'Non précisé' }}</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Participants maximum</h6>
                            <p class="mb-0 fw-semibold">{{ session.maxParticipants }}</p>
                        </div>
                    </div>
                </div>
            </div>

            {# Notes #}
            {% if session.notes %}
                <div class="card shadow-sm mb-4">
                    <div class="card-header">
                        <h6 class="mb-0">Notes internes</h6>
                    </div>
                    <div class="card-body">
                        {{ session.notes }}
                    </div>
                </div>
            {% endif %}

            {# Métadonnées #}
            <div class="card shadow-sm">
                <div class="card-body small text-muted d-flex justify-content-between">
                    <div>
                        <strong>Créé le</strong><br>
                        {{ session.createdAt|format_datetime(pattern: "dd/MM/yyyy 'à' HH'h'mm") }}
                    </div>
                    <div>
                        <strong>Modifié le</strong><br>
                        {% if session.updatedAt %}
                            {{ session.updatedAt|format_datetime(pattern: "dd/MM/yyyy 'à' HH'h'mm") }}
                        {% else %}
                            Jamais modifié
                        {% endif %}
                    </div>
                </div>
            </div>

        </div>

        {# Colonne droite - Service associé uniquement #}
        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header">
                    <h6 class="mb-0">Service associé</h6>
                </div>
                <div class="card-body">
                    {% if session.service.image %}
                        <img src="{{ vich_uploader_asset(session.service, 'imageFile') }}" 
                             class="img-fluid rounded mb-3 w-100" 
                             alt="{{ session.service.name }}">
                    {% endif %}
                    <strong class="d-block mb-1">{{ session.service.name }}</strong>
                    <small class="text-muted d-block mb-2">{{ session.service.displayDuration }}</small>
                    <span class="fw-bold fs-5">{{ session.service.price }} €</span>
                </div>
            </div>
        </div>

    </div>

</div>

{% endblock %}