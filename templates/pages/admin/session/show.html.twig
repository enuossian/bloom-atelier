{% extends 'themes/base_admin.html.twig' %}

{% block title %}Session —
	{{ session.service.name }}
	du
	{{ session.startTime|format_datetime(pattern: "dd/MM/yyyy 'à' HH'h'mm") }}
{% endblock %}
{% block description %}Détails de la session
	{{ session.service.name }}
	du
	{{ session.startTime|format_datetime(pattern: "dd/MM/yyyy 'à' HH'h'mm") }}
{% endblock %}
{% block keywords %}Session, Détail,
	{{ session.service.name }}
{% endblock %}

{% block main %}
	<h1 class="display-6 text-center cormorant-garamond">{{ session.service.name }}</h1>
	<div class="container">
		<div class="d-flex justify-content-end align-items-center mb-5">
			<a href="{{ path('app_admin_session_index') }}" class="btn btn-brown rounded-0 px-4 py-2">← Retour</a>
		</div>
	</div>
	<div class="row g-3 mb-5">
		<div class="col-6 col-lg-6">
			<div class="card border rounded-0 p-4 container-bg">
				<p class="pink small text-uppercase fw-light mb-1">Statut</p>
				<span class="cormorant-garamond fs-4">{{ session.status.label }}</span>
			</div>
		</div>
		<div class="col-6 col-lg-6">
			<div class="card border rounded-0 p-4 container-bg">
				<p class="pink small text-uppercase fw-light mb-1">Places max</p>
				<span class="cormorant-garamond fs-4">{{ session.maxParticipants }}</span>
			</div>
		</div>
	</div>

	<div
		class="row g-4">

		{# Détails de la session #}
		<div class="col-lg-6">
			<div class="card border rounded-0 p-4 container-bg h-100">
				<h2 class="cormorant-garamond pink fs-4 fw-light mb-4">Détails de la session</h2>
				<table class="table fw-light">
					<tbody>
						<tr>
							<td class="text-secondary small text-uppercase">Référence</td>
							<td>{{ session.reference }}</td>
						</tr>
						<tr>
							<td class="text-secondary small text-uppercase">Début</td>
							<td>{{ session.startTime|format_datetime(pattern: "dd/MM/yyyy 'à' HH'h'mm") }}</td>
						</tr>
						<tr>
							<td class="text-secondary small text-uppercase">Fin</td>
							<td>{{ session.endTime|format_datetime(pattern: "HH'h'mm") }}</td>
						</tr>
						<tr>
							<td class="text-secondary small text-uppercase">Lieu</td>
							<td>{{ session.location ?? 'Non précisé' }}</td>
						</tr>
						<tr>
							<td class="text-secondary small text-uppercase">Créé le</td>
							<td>{{ session.createdAt|format_datetime(pattern: "dd/MM/yyyy 'à' HH'h'mm") }}</td>
						</tr>
						<tr>
							<td class="text-secondary small text-uppercase">Modifié le</td>
							<td>{{ session.updatedAt ? session.updatedAt|format_datetime(pattern: "dd/MM/yyyy 'à' HH'h'mm") : '—' }}</td>
						</tr>
					</tbody>
				</table>
			</div>
		</div>

		<div class="col-lg-6">
			<div class="card border rounded-0 p-4 container-bg h-100">
				<h2 class="cormorant-garamond pink fs-4 fw-light mb-4">Service associé</h2>
				<table class="table fw-light">
					<tbody>
						<tr>
							<td class="text-secondary small text-uppercase">Nom</td>
							<td>{{ session.service.name }}</td>
						</tr>
						<tr>
							<td class="text-secondary small text-uppercase">Prix</td>
							<td>{{ session.service.price }}
								€</td>
						</tr>
						<tr>
							<td class="text-secondary small text-uppercase">Durée</td>
							<td>{{ session.service.displayDuration }}</td>
						</tr>
						<tr>
							<td class="text-secondary small text-uppercase">Créé le</td>
							<td>{{ session.service.createdAt|format_datetime(pattern: "dd/MM/yyyy 'à' HH'h'mm") }}</td>
						</tr>
						<tr>
							<td class="text-secondary small text-uppercase">Modifié le</td>
							<td>{{ session.service.updatedAt|format_datetime(pattern: "dd/MM/yyyy 'à' HH'h'mm") }}</td>
						</tr>
					</tbody>
				</table>
				<a href="{{ path('app_visitor_service_show', {'id': session.service.id, 'slug': session.service.slug})}}" target="_blank" class="btn btn-clear rounded-0 px-4 py-2 mt-auto">Voir le service</a>
			</div>
		</div>

		<div class="col-12">
			<div class="card border rounded-0 p-4 container-bg">
				<h2 class="cormorant-garamond pink fs-4 fw-light mb-4">Participants</h2>

				{% if session.bookItems is not empty %}
					<table class="table table-hover fw-light align-middle">
						<thead class="table-danger">
							<tr>
								<th class="fw-light text-uppercase small">Utilisateur</th>
								<th class="fw-light text-uppercase small">Email</th>
								<th class="fw-light text-uppercase small">Réservation</th>
								<th class="fw-light text-uppercase small">Options</th>
							</tr>
						</thead>
						<tbody>
							{% for bookItem in session.bookItems %}
								<tr>
									<td>
										{{ bookItem.booking.user.firstName }}
										{{ bookItem.booking.user.lastName }}
									</td>
									<td>{{ bookItem.booking.user.email }}</td>
									<td>{{ bookItem.booking.reference }}</td>
									<td>
										<a href="{{path('app_admin_booking_show', {'id': bookItem.booking.id})}}" class="btn btn-sm btn-clear rounded-0">voir</a>
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				{% else %}
					<p class="text-secondary">Aucun participant pour le moment.</p>
				{% endif %}
			</div>
		</div>
        <div class="col-12 mb-5">
			<div class="card border rounded-0 p-4 container-bg h-100">
				<h2 class="cormorant-garamond pink fs-4 fw-light mb-4">Notes internes</h2>
                {% if session.notes %}
                    <p>{{ session.notes }}</p>
                {% else %}
                    <p class="text-secondary">Aucune note pour le moment.</p>
                {% endif %}
			</div>
		</div>
	</div>
{% endblock %}
