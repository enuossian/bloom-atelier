{% extends 'themes/base_visitor.html.twig' %}

{% block title %}
	{{ service.name }}
	— Bloom Atelier
{% endblock %}

{% block description %}Consultez les informations détaillées du service
	{{ service.name }}
{% endblock %}

{% block keywords %}service, détail,
	{{ service.name }}
{% endblock %}

{% block font_awesome %}<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
{% endblock %}

{% block main %}

	{% include 'components/_alert.html.twig' %}

	<div class="container my-4">
		<a href="{{path('app_visitor_service_index')}}" class="text-decoration-none">← Voir tous nos services</a>
	</div>

	<header>
		<div class="container my-5">
			<div class="row align-items-center g-5">

				<div class="col-md-6 order-md-2">
					{% if service.image %}
						<img src="{{ vich_uploader_asset(service, 'imageFile') }}" class="w-100 object-fit-cover rounded-0 shadow-sm" style="height: 60vh;" alt="{{ service.name }}">
					{% else %}
						<img src="{{ asset('images/static/hero-img.jpg') }}" class="w-100 object-fit-cover rounded-0 shadow-sm" style="height: 60vh;" alt="Image par défaut du service {{ service.name }}">
					{% endif %}
				</div>

				{# Contenu #}
				<div class="col-md-6 order-md-1 d-flex flex-column justify-content-center">

					<h1 class="display-4 pink fw-light cormorant-garamond mb-4">
						{{ service.name }}
					</h1>

					<div class="fw-light text-muted mb-4">
						{{ service.shortDescription }}
					</div>

					<div class="d-flex gap-5 mb-5">

						<div>
							<span class="d-block cormorant-garamond fs-2">
								{{ service.price }}€
							</span>
							<small class="text-muted text-uppercase">Prix</small>
						</div>

						<div>
							<span class="d-block cormorant-garamond fs-2">
								{{ service.displayDuration }}
							</span>
							<small class="text-muted text-uppercase">Durée</small>
						</div>

					</div>

					<a href="{{ path('app_visitor_service_show', {'id': service.id, 'slug': service.slug}) }}#upcomingSessions" class="btn btn-brown px-5 py-3 rounded-0 align-self-start">
						Voir les sessions disponibles
					</a>

				</div>

			</div>
		</div>
	</header>

	<section class="bg-white py-5 my-5">
		<div class="container">
			<div class="mb-5">
				<h2 class="display-6 fw-normal cormorant-garamond mb-5">
					Déroulement de la
					<span class="display-6 fw-normal cormorant-garamond pink">session</span>
				</h2>
				<div>{{ service.description|raw }}</div>
			</div>

		</div>
	</section>

	<section class="py-5 my-5" id="upcomingSessions">
		<div class="container">
			<h2 class="display-6 fw-normal cormorant-garamond mb-5">
				Sessions
				<span class="display-6 fw-normal cormorant-garamond pink">disponibles</span>
			</h2>

			{% for session in sessions %}
				<div class="d-flex align-items-center justify-content-between gap-3 bg-white border rounded p-4 mb-2">
					<div>
						<p class="fw-semibold mb-1">{{ session.startTime|format_date(pattern: "dd/MM/yyyy 'de' HH'h'mm") }}
							{{ session.endTime|format_date(pattern: "'à' HH'h'mm") }}
						</p>
						<p class="text-muted small mb-0">{{ session.maxParticipants - session.paidCount }}
							place(s) disponible(s) sur
							{{ session.maxParticipants }}</p>
						<p class="text-muted small mb-0">{{ session.location ?? 'Lieu à définir' }}</p>
					</div>
					<form action="{{ path('app_user_booking_create', {'id': session.id}) }}" method="POST">
						<input type="hidden" name="csrf_token" value="{{ csrf_token('booking-create' ~ session.id) }}">
						<input type="submit" value="Réserver" class="btn btn-brown rounded-0 px-4 py-2">
					</form>
				</div>
			{% else %}
				<div class="alert alert-light">Aucune session disponible pour le moment.</div>
			{% endfor %}
		</div>
	</section>

	<section class="bg-brown text-light py-5">
		{% if comments is not empty %}
			<div class="container">

				<div class="mb-5">
					<h2 class="display-6 fw-light cormorant-garamond">
						Vos
						<span class="pink cormorant-garamond display-6 fw-light ">témoignages</span>
					</h2>
				</div>

				<div class="row g-4">
					{% for comment in comments %}
						<div class="col-12 col-md-4">
							<div class="border border-light border-opacity-25 p-4 h-100 d-flex flex-column gap-3 bg-light-brown">

								<div class="pink">
									{{ comment.displayStars|raw }}
								</div>

								<p class="cormorant-garamond fst-italic fw-light fs-5 flex-grow-1 text-brown-light">
									«
									{{ comment.content }}
									»
								</p>

								<div class="border-top border-light border-opacity-25 pt-3">
									<strong class="d-block small">
										{{ comment.user.firstName }}
										{{ comment.user.lastName|first }}.
									</strong>
									<small>
										{{ comment.createdAt|format_date(pattern: "dd/MM/yyyy") }}
									</small>
								</div>

							</div>
						</div>
					{% endfor %}
				</div>
			</div>
		{% endif %}
	</section>

	<section>
		<div class="container my-5">
			<h2 class="display-6 fw-normal cormorant-garamond mb-5">
				Donnez votre
				<span class="display-6 fw-normal cormorant-garamond pink">avis</span>
			</h2>
			{% if not app.user %}
				<div class="alert alert-light d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
					<p class="mb-0">Connectez-vous pour partager votre avis sur ce service.</p>
					<a href="{{ path('app_login') }}" class="btn btn-brown rounded-0 px-4 py-2">Se connecter</a>
				</div>
			{% elseif not hasBookedService %}
				<div class="alert alert-light">
					<p class="mb-0">Seules les personnes ayant réservé ce service peuvent laisser un avis.</p>
				</div>
			{% else %}
				<div id="comment-container">
					{{ form_start(commentForm, {'action': path('app_visitor_service_show', {'id': service.id, 'slug': service.slug})~'#comment-container'}) }}
					<div class="mb-3">
						<label for="comment_form_rating" class="form-label">Note</label>
						{{ form_widget(commentForm.rating) }}
						<div class="text-danger">{{ form_errors(commentForm.rating) }}</div>
					</div>
					<div>
						<label for="comment_form_content" class="form-label">Commentaire</label>
						{{ form_widget(commentForm.content) }}
						<div class="text-danger">{{ form_errors(commentForm.content) }}</div>
					</div>
					<div class="mt-4 text-end">
						<input formnovalidate type="submit" value="Publier mon avis" class="btn btn-brown rounded-0 px-4 py-2">
					</div>
					{{ form_end(commentForm) }}
				</div>
			{% endif %}
		</div>
	</section>


{% endblock %}
