{% extends "themes/base_visitor.html.twig" %}

{% block title %}Accueil - Bloom Atelier
{% endblock %}
{% block description %}Accueil - Réservez votre session de maquillage
{% endblock %}
{% block keywords %}maquillage, session, réservation, atelier
{% endblock %}

{% block main %}

	<!-- Hero section  -->

	<header>
		<div class="container my-5">
			<div class="row">
				<div class="col-md-6 order-md-2 d-flex justify-content-center align-items-center">
					<img src="{{ asset('images/static/hero-img.jpg') }}" alt="Image de Hawa Diallo" class="img-fluid">
				</div>
				<div class="col-md-6 order-md-1 d-flex flex-column justify-content-center align-items-center gap-5">
					<h1 class="display-3 fw-light my-4 cormorant-garamond">L'art de
						<span class="display-3 pink cormorant-garamond">révéler</span>
						votre beauté</h1>
					<p>
						Des sessions personnalisées pour apprendre les techniques de beauté dans un espace doux et bienveillant, pensé entièrement pour vous.
					</p>
					<div class="d-flex gap-5 mb-5">
						<a href="{{ path('app_visitor_service_index') }}" class="btn btn-brown px-5 py-3 rounded-0">Découvrir</a>
						<a href="{{ path('app_visitor_contact_index') }}" class="btn btn-clear px-5 py-3 rounded-0">Nous contacter</a>
					</div>
				</div>
			</div>
		</div>
	</header>

	<!-- Prestations -->
	<section class="bg-white py-5">
		<div class="container-fluid px-lg-5">
			<div class="mb-5">
				<h2 class="display-6 fw-light cormorant-garamond">
					Nos prestations
					<span class="display-6 fw-light cormorant-garamond pink">phares</span>
				</h2>
			</div>
			<div
				class="row g-4 align-items-stretch">

				{# Card principale #}

				{% if services is not empty %}

					{% set service = services|first %}
					<div class="col-12 col-lg-5">
						<div class="card h-100 bg-brown text-light border-0 rounded-0 p-4 p-lg-5 d-flex flex-column justify-content-between">

							<div class="card-body p-0">
								<h3 class="card-title fw-light fs-2 cormorant-garamond mb-3">
									{{ service.name }}
								</h3>

								<p class="card-text opacity-75 mb-4">
									{{ service.shortDescription|raw }}
								</p>

								<div class="d-flex gap-4 mb-4">
									<div>
										<strong class="d-block fs-4 cormorant-garamond">
											{{ service.price }}
											€
										</strong>
										<small class="opacity-50">Prix</small>
									</div>
									<div>
										<strong class="d-block fs-4 cormorant-garamond">
											{{ service.displayDuration }}
										</strong>
										<small class="opacity-50">Durée</small>
									</div>
								</div>
							</div>

							<div class="card-footer border-0 p-0">
								<a href="{{ path('app_visitor_service_show', {'id': service.id, 'slug': service.slug}) }}" class="btn btn-clear text-light rounded-0 px-4 py-2">
									Découvrir →
								</a>
							</div>

						</div>
					</div>

					{# Cards secondaires #}
					<div class="col-12 col-lg-7">
						<div
							class="row g-4">

							{# Slice : 1 position de départ 2 nombre d'éléments à prendre #}
							{% for service in services|slice(1, 2) %}
								<div class="col-12">
									<div class="card h-100 border rounded-0 p-4 p-lg-5 d-flex flex-column justify-content-between">

										<div class="card-body p-0">
											<h3 class="card-title fw-light fs-3 cormorant-garamond mb-3">
												{{ service.name }}
											</h3>

											<p class="card-text opacity-75 mb-4">
												{{ service.shortDescription }}
											</p>
										</div>

										<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3">

											<div class="d-flex gap-4">
												<div>
													<strong class="d-block fs-5 cormorant-garamond">
														{{ service.price }}
														€
													</strong>
													<small class="opacity-50">Prix</small>
												</div>
												<div>
													<strong class="d-block fs-5 cormorant-garamond">
														{{ service.displayDuration }}
													</strong>
													<small class="opacity-50">Durée</small>
												</div>
											</div>

											<a href="{{ path('app_visitor_service_show', {'id': service.id, 'slug': service.slug}) }}" class="btn btn-outline-dark rounded-0 px-4 py-2">
												Découvrir →
											</a>

										</div>

									</div>
								</div>
							{% endfor %}

						</div>
					</div>

				{% else %}
					<div class="col-12 text-center py-5">
						<p class="fs-4">Aucun service disponible pour le moment. Revenez bientôt !</p>
					</div>
				{% endif %}
			</div>
		</div>
	</section>

	<!-- Demande spécifique -->

	<section>
		<div class="container-fluid py-5 bg-beige">
			<div class="text-center">
				<h4 class="display-6 fw-light cormorant-garamond">Vous avez une demande spécifique ?</h4>
				<p>Nous pouvons adapter nos prestations à vos besoins particuliers.</p>
				<a href="{{ path('app_visitor_contact_index') }}" class="btn btn-brown rounded-0 px-4 py-2 text-light">Contactez-nous</a>
			</div>
		</div>
	</section>

	<!-- À propos -->

	<section class="my-5">
		<div class="container-fluid px-lg-5">
			<div class="row align-items-center g-5">
				<div class="col-md-6 text-center">
					<img src="{{ asset('images/static/front-hero1.jpg') }}" alt="Hawa Diallo - fondatrice de Bloom Atelier" class="img-fluid w-75 shadow-sm">
				</div>
				<div class="col-md-6">
					<h2 class="display-6 fw-light cormorant-garamond mb-2">
						Notre
						<span class="display-6 fw-light cormorant-garamond pink">histoire</span>
					</h2>
					<p class="fs-5 text-muted mb-4">Hawa Diallo, fondatrice
					</p>
					<div class="d-flex flex-column gap-3 mb-4">
						<p class="mb-0">
							Passionnée par l'univers de la beauté depuis plus de 10 ans, Hawa Diallo a fondé Bloom Atelier avec une conviction profonde : chaque personne porte en elle une beauté unique qui ne demande qu'à s'épanouir.
						</p>
						<p class="mb-0">
							Formée aux techniques de maquillage professionnel à Paris, elle a travaillé dans le cinéma, la mode et le mariage avant de se consacrer à l’accompagnement individuel.
						</p>
						<p class="mb-0">
							Spécialisée en maquillage, relooking et colorimétrie, elle vous accompagne pour révéler votre style personnel.
						</p>
					</div>
					<a href="{{ path('visitor_home_about_us') }}" class="btn btn-brown rounded-0 px-4 py-2">En savoir plus</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Avis clients -->
	<section class="bg-brown text-light py-5">
		<div class="container-fluid px-lg-5">

			<div class="mb-5">
				<h2 class="display-6 fw-light cormorant-garamond">
					Vos
					<span class="pink cormorant-garamond display-6 fw-light ">témoignages</span>
				</h2>
			</div>

			{% if comments is not empty %}
				<div class="row g-4">
					{% for comment in comments %}
						<div class="col-12 col-md-4">
							<div class="border border-light border-opacity-25 p-4 h-100 d-flex flex-column gap-3 bg-light-brown">

								<div class="pink">
									{{ comment.displayStars|raw }}
								</div>

								<p class="cormorant-garamond fst-italic fw-light fs-5 flex-grow-1 text-brown-light">
									«
									{{ comment.content }}
									»
								</p>

								<div class="border-top border-light border-opacity-25 pt-3">
									<strong class="d-block small">
										{{ comment.user.firstName }}
										{{ comment.user.lastName|first }}.
									</strong>
									<small class="pink">
										{{ comment.service.name }}
									</small>
								</div>

							</div>
						</div>
					{% endfor %}
				</div>
			{% else %}
				<p class="text-light">Aucun avis disponible pour le moment.</p>
			{% endif %}

		</div>
	</section>

	<!-- Engagement -->

	<section>
		<div class="container-fluid my-5 py-5">
			<div class="text-center">
				<h2 class="display-3 fw-light cormorant-garamond">
					Prêtes à
					<span class="pink cormorant-garamond display-3 fw-light">commencer ?</span>
				</h2>
				<p>Réservez votre session dès maintenant et offrez-vous un moment rien que pour vous.</p>
				<a href="{{ path('app_visitor_service_index') }}" class="btn btn-brown rounded-0 px-4 py-2 text-light">Réserver une session</a>
			</div>
		</div>
	</section>


{% endblock %}
