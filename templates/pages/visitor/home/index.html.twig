{% extends "themes/base_visitor.html.twig" %}

{% block title %}Accueil - Bloom Atelier{% endblock %}
{% block description %}Accueil - Réservez votre session de maquillage{% endblock %}
{% block keywords %}maquillage, session, réservation, atelier{% endblock %}

{% block main %}
<section class="py-5">
    <div class="container rounded-4 py-5 px-4">
        <div class="row align-items-center g-4">
            <div class="col-lg-6 order-2 order-lg-1">
                <div class="m-3">
                    <h1 class="display-4 mb-4">Sublimez votre style avec Bloom Atelier</h1>
                    <p class="lead mb-4">
                        Participez à nos sessions de maquillage en petit groupe et découvrez nos conseils personnalisés.
                    </p>
                    <a href="#" class="btn btn-dark btn-lg rounded-pill w-75 p-3">
                        Découvrir
                    </a>
                </div>
            </div>
            <div class="col-lg-6 d-flex justify-content-center order-1 order-lg-2">
                <img src="/images/static/femme.jpg" alt="Session de maquillage" class="img-fluid rounded w-100">
            </div>
        </div>
    </div>
</section>
{% endblock %}
