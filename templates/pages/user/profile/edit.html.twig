{% extends 'themes/base_admin.html.twig' %}

{% block title %}Modification du profil{% endblock %}

{% block description %}Modifier les informations du profil{% endblock %}

{% block main %}
    <h1 class="text-center my-3 display-5">Modification du profil</h1>

    <div class="container mt-5">
        <div class="row">
            <div class="col-md-10 col-lg-5 mx-auto p-4 shadow bg-light">
                {{ form_start(profileForm) }}
                    <div class="mb-3">
                        <label for="profile_form_firstName">Prénom <span class="text-danger">*</span></label>
                        {{ form_widget(profileForm.firstName) }}
                        <div class="text-danger">{{ form_errors(profileForm.firstName) }}</div>
                    </div>
                    <div class="mb-3">
                        <label for="profile_form_lastName">Nom <span class="text-danger">*</span></label>
                        {{ form_widget(profileForm.lastName) }}
                        <div class="text-danger">{{ form_errors(profileForm.lastName) }}</div>
                    </div>      
                    <div class="text-center">
                        <input formnovalidate type="submit" value="Modifier" class="btn btn-dark shadow w-100">
                    </div>                              
                {{ form_end(profileForm) }}
            </div>
        </div>
    </div>
    
    
{% endblock %}
