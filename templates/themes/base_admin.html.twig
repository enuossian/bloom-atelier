<!DOCTYPE html>
<html lang="fr" data-bs-theme="auto">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<meta name="description" content="{% block description %}{% endblock %}">
		<meta name="author" content="Hawa Diallo">
		<meta name="publisher" content="Enuossian">
		<meta name="keywords" content="{% block keywords %} {% endblock %}">
		<meta name="theme-color" content="#d4857a">
		<title>
			{% block title %}{% endblock %}
			· Bloom Atelier</title>

		{# Webpack Encore #}
		{% block stylesheets %}
			{{ encore_entry_link_tags('app') }}
		{% endblock %}

		{% block javascripts %}
			{{ encore_entry_script_tags('app') }}
		{% endblock %}

		{# Favicon #}
		<link rel="icon" href="/favicon.ico?v=1">

		{# Google Font #}
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link
		href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300..700;1,300..700&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">

		{# Font Awesome #}
		<link
		rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer">

		{# Jquery #}
		{% block j_query %}{% endblock %}

		{# DataTables #}
		{% block data_tables %}{% endblock %}

		{# Select 2 #}
		{% block select2 %}{% endblock %}

		{# Tiny_mce #}
		{% block tiny_mce %}{% endblock %}

		{# style #}
		<style>
			.bg-brown {
				background-color: #3d2e27 !important;
			}

			html,
			body {
				height: 100%;
			}

			body {
				overflow-x: hidden;
			}

			.navbar-brand {
				background: #3d2e27;
				color: #fff !important;
				padding: 0.75rem 1rem;
			}

			@media(max-width: 767.98px) {
				.navbar-brand {
					background: transparent !important;
					color: #3d2e27 !important;
				}
			}

			.sidebar-link {
				color: #b5a49a;
				padding: 0.6rem 1rem;
				display: flex;
				align-items: center;
				gap: 0.5rem;
				text-decoration: none;
				transition: background 0.2s ease;
			}

			.sidebar-link:hover {
				background: rgba(255, 255, 255, 0.08);
				color: #ffffff;
			}

			hr {
				border-color: rgba(255, 255, 255, 0.2);
				margin: 1rem 0;
			}

			.offcanvas {
				background: #3d2e27;
				color: #fff;
			}

			#sidebarMenu {
				min-height: 100vh;
				height: 100%;
			}
		</style>
	</head>

	<body>

		{# ================= HEADER ================= #}
		<header class="navbar p-0 d-flex align-items-center">

			<a class="navbar-brand col-md-3 col-lg-2" href="{{ path('visitor_home_index') }}">
				Bloom Atelier
			</a>

			<button class="btn d-md-none ms-auto me-3" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu" aria-controls="sidebarMenu">
				<i class="fa-solid fa-bars"></i>
			</button>

		</header>

		<div class="container-fluid">
			<div
				class="row">

				{# ================= SIDEBAR ================= #}
				<nav
					id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block bg-brown p-0 offcanvas-md offcanvas-start h-100">

					<!-- MOBILE HEADER -->
					<div class="offcanvas-header d-md-none">

						<button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" data-bs-target="#sidebarMenu" aria-label="Close"></button>
					</div>

					<div class="offcanvas-body p-0 d-flex flex-column">

						<a class="sidebar-link" href="{{path('app_admin_home')}}">
							<i class="fa-solid fa-house"></i>
							Tableau de bord
						</a>

						<a class="sidebar-link" href="{{path('app_admin_service_index')}}">
							<i class="fa-solid fa-spa"></i>
							Services
						</a>

						<a class="sidebar-link" href="{{path('app_admin_session_index')}}">
							<i class="fa-solid fa-calendar"></i>
							Sessions
						</a>

						<a class="sidebar-link" href="{{path('app_admin_booking_index')}}">
							<i class="fa-solid fa-file-invoice"></i>
							Réservations
						</a>

						<a class="sidebar-link" href="{{path('app_admin_user_index')}}">
							<i class="fa-solid fa-users"></i>
							Utilisateurs
						</a>

						<a class="sidebar-link" href="{{path('app_admin_contact_index')}}">
							<i class="fa-solid fa-envelope"></i>
							Contact
						</a>

						<a class="sidebar-link" href="{{path('app_admin_comment_index')}}">
							<i class="fa-solid fa-star"></i>
							Avis
						</a>

						<hr>

						<a class="sidebar-link" href="{{path('app_admin_profile_index')}}">
							<i class="fa-solid fa-user"></i>
							Profil
						</a>

						<a class="sidebar-link" href="{{path('app_admin_setting_index')}}">
							<i class="fa-solid fa-gear"></i>
							Paramètres
						</a>

						<hr>
						
						<a class="sidebar-link" href="{{path('app_user_home')}}">
							<i class="fa-solid fa-outdent"></i>
							Espace utilisateur
						</a>

						<a class="sidebar-link" href="{{path('visitor_home_index')}}">
							<i class="fa-solid fa-arrow-rotate-left"></i>
							Retour site
						</a>

						<a class="sidebar-link" href="{{path('app_logout')}}">
							<i class="fa-solid fa-right-from-bracket"></i>
							Déconnexion
						</a>

					</div>
				</nav>

				{# ================= MAIN ================= #}
				<main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-3"> {% block main %}{% endblock %}
					</main>

				</div>
			</div>

		</body>
	</html>
